# =============================================================================
# Apex Growth — Lead Pipeline Environment Variables
# =============================================================================
# Copy this file to .env and fill in each value.
# Never commit .env to version control.
# =============================================================================

# GOOGLE PLACES API KEY
# 1. Go to console.cloud.google.com
# 2. Create a new project or select an existing one
# 3. Go to APIs & Services > Library
# 4. Search for "Places API" and click Enable
# 5. Go to APIs & Services > Credentials > Create Credentials > API Key
# 6. Click "Restrict Key": under API restrictions select "Places API" only
# 7. Copy the key below
GOOGLE_PLACES_API_KEY=

# NOTION API TOKEN
# 1. Go to notion.so/my-integrations
# 2. Click "New Integration"
# 3. Name it "Apex Lead Pipeline", select your workspace
# 4. Copy the Internal Integration Token below
# 5. IMPORTANT: Open your Notion database, click the three dots (top right),
#    click "Add connections" and add this integration
NOTION_TOKEN=

# NOTION DATABASE ID
# Already extracted from the database URL
NOTION_DATABASE_ID=a8b006272ecc4a098ba5b3ad6887ab3d

# APIFY TOKEN
# 1. Go to console.apify.com
# 2. Click Settings > Integrations > API Tokens
# 3. Copy your personal API token below
# Free tier gives $5/month of compute, enough for ~3000 pages/day
APIFY_TOKEN=

# ENRICHER SETTINGS
# How many domains to send to Apify per API call (max ~50)
ENRICHER_BATCH_SIZE=25
# Max records to enrich per pipeline run (controls Apify spend)
ENRICHER_DAILY_CAP=150

# CRON SCHEDULE (for local node-cron runner)
# Format: minute hour day month weekday (UTC)
# Default: every day at 6am UTC (8am SAST)
CRON_SCHEDULE=0 6 * * *
